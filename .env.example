# ============================================================
# ResumeForge — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── AI Provider ─────────────────────────────────────────────
# Choose ONE provider. Set AI_PROVIDER to match.
AI_PROVIDER=openai           # Options: openai | anthropic | groq

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Anthropic / Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (https://console.groq.com/)
GROQ_API_KEY=gsk_...

# ── App Settings ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ResumeForge

# ── Stripe (optional — for premium upgrade) ─────────────────
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=price_...

# ── Lemon Squeezy alternative ───────────────────────────────
# LEMONSQUEEZY_API_KEY=...
# NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=https://...

# ── Auth (optional — for Clerk) ─────────────────────────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
# CLERK_SECRET_KEY=sk_...
